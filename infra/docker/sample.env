# Скопируйте в .env в этом каталоге или экспортируйте переменные для cargo run с localhost.
DATABASE_URL=postgres://app:app@localhost:5432/service_processes
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
JOB_QUEUE_NAME=service_jobs
JWT_SECRET=dev-secret-change-me-please
RUST_LOG=info
