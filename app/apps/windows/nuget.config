<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!-- Корпоративный NuGet (пример). Замените на ваш Artifactory/Nexus/Azure Artifacts -->
    <add key="corp-nuget" value="https://nuget.example.corp/v3/index.json" />
    <!-- При необходимости разрешите nuget.org -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>


